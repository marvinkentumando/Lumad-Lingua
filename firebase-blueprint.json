{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user progress, stats, and collected artifacts.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["learner", "contributor", "validator", "educator", "admin"], "description": "The user's role in the system." },
        "xp": { "type": "integer", "description": "Total experience points earned." },
        "streak": { "type": "integer", "description": "Current daily learning streak." },
        "level": { "type": "integer", "description": "Current learning level." },
        "lives": { "type": "integer", "description": "Current number of lives (max 5)." },
        "lastLifeLostAt": { "type": "string", "format": "date-time", "description": "The timestamp when the last life was lost." },
        "lastLessonDate": { "type": "string", "format": "date", "description": "ISO date of the last completed lesson." },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of unlocked artifact IDs."
        },
        "onboarded": { "type": "boolean", "description": "Whether the user has completed onboarding." },
        "completedLessons": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of completed lesson IDs."
        },
        "lastActive": { "type": "string", "format": "date-time", "description": "The last time the user was active." }
      },
      "required": ["uid", "role", "xp", "streak", "level", "lives", "onboarded", "completedLessons"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a specific user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the notification." },
        "userId": { "type": "string", "description": "The UID of the user who should receive this notification." },
        "title": { "type": "string", "description": "The title of the notification." },
        "message": { "type": "string", "description": "The message body of the notification." },
        "type": { "type": "string", "enum": ["validation", "challenge", "system", "social"], "description": "The category of the notification." },
        "read": { "type": "boolean", "description": "Whether the notification has been read." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the notification was created." },
        "link": { "type": "string", "description": "An optional link to navigate to when the notification is clicked." }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A structured learning module created by an educator.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the lesson." },
        "title": { "type": "string", "description": "Title of the lesson." },
        "description": { "type": "string", "description": "A brief overview of the lesson." },
        "educatorId": { "type": "string", "description": "The UID of the educator who created this lesson." },
        "dialect": { "type": "string", "description": "The dialect or community this lesson focuses on." },
        "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"], "description": "The difficulty level." },
        "wordIds": { "type": "array", "items": { "type": "string" }, "description": "List of words included in this lesson." },
        "quizIds": { "type": "array", "items": { "type": "string" }, "description": "List of quizzes associated with this lesson." },
        "status": { "type": "string", "enum": ["draft", "published"], "description": "The publication status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lesson was created." }
      },
      "required": ["title", "educatorId", "dialect", "difficulty", "status", "createdAt"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "An interactive assessment within a lesson.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the quiz." },
        "lessonId": { "type": "string", "description": "The ID of the lesson this quiz belongs to." },
        "title": { "type": "string", "description": "Title of the quiz." },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["multiple-choice", "matching", "audio-recognition", "translation"], "description": "The type of question." },
              "prompt": { "type": "string", "description": "The question prompt or text." },
              "options": { "type": "array", "items": { "type": "string" }, "description": "Possible answers (for multiple-choice)." },
              "correctAnswer": { "type": "string", "description": "The correct answer." },
              "audioUrl": { "type": "string", "description": "Optional audio for audio-recognition questions." }
            },
            "required": ["type", "prompt", "correctAnswer"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the quiz was created." }
      },
      "required": ["lessonId", "title", "questions", "createdAt"]
    },
    "Word": {
      "title": "Word Entry",
      "description": "A dictionary entry, which can be a word or a phrase.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the word." },
        "term": { "type": "string", "description": "The word or phrase in the native language." },
        "phonetic": { "type": "string", "description": "Phonetic pronunciation." },
        "meaning": { "type": "string", "description": "Translation or meaning in English." },
        "example": { "type": "string", "description": "An example sentence using the word." },
        "audioUrl": { "type": "string", "format": "uri", "description": "URL to the audio recording." },
        "contributorId": { "type": "string", "description": "UID of the user who contributed this word." },
        "dialect": { "type": "string", "description": "The community or dialect this word belongs to." },
        "status": { "type": "string", "enum": ["pending", "validated", "rejected"], "description": "The validation status of the word." },
        "validatorId": { "type": "string", "description": "UID of the validator who reviewed this word." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the word was submitted." }
      },
      "required": ["term", "meaning", "contributorId", "status", "createdAt"]
    },
    "SRSReview": {
      "title": "SRS Review Data",
      "description": "Spaced Repetition System data for a specific word for a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user's UID." },
        "wordId": { "type": "string", "description": "The word's ID." },
        "nextReview": { "type": "string", "format": "date-time", "description": "When the word should be reviewed next." },
        "interval": { "type": "integer", "description": "The current review interval in days." },
        "easeFactor": { "type": "number", "description": "The difficulty factor for the word (SuperMemo-2 style)." },
        "consecutiveCorrect": { "type": "integer", "description": "Number of times the user got this word right in a row." }
      },
      "required": ["userId", "wordId", "nextReview", "interval", "easeFactor"]
    },
    "Challenge": {
      "title": "Community Challenge",
      "description": "A collaborative weaving challenge for the community.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the challenge." },
        "title": { "type": "string", "description": "Title of the challenge." },
        "description": { "type": "string", "description": "Description of the challenge." },
        "goalXp": { "type": "integer", "description": "Total XP goal for the community." },
        "currentXp": { "type": "integer", "description": "Current XP contributed by the community." },
        "endsAt": { "type": "string", "format": "date-time", "description": "When the challenge ends." },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "List of participant UIDs." }
      },
      "required": ["title", "goalXp", "currentXp", "endsAt"]
    },
    "CulturalSite": {
      "title": "Cultural Site",
      "description": "An ancestral domain, sacred site, or cultural hub on the map.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the site." },
        "name": { "type": "string", "description": "The name of the site." },
        "community": { "type": "string", "description": "The community or tribe associated with the site." },
        "type": { "type": "string", "description": "The category of the site (e.g., Sacred Site, Ancestral Domain)." },
        "coords": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[latitude, longitude]"
        },
        "population": { "type": "integer", "description": "Estimated population in the area." },
        "dialect": { "type": "string", "description": "The primary dialect spoken." },
        "status": { "type": "string", "description": "Current status (e.g., Active, Protected, UNESCO)." },
        "description": { "type": "string", "description": "A brief history or description of the site." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the site was added." }
      },
      "required": ["name", "community", "type", "coords", "population", "dialect", "status", "description"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profile data." },
    "/words/{wordId}": { "schema": "Word", "description": "Dictionary entries." },
    "/users/{userId}/reviews/{reviewId}": { "schema": "SRSReview", "description": "User-specific SRS data." },
    "/challenges/{challengeId}": { "schema": "Challenge", "description": "Community challenges." },
    "/cultural_sites/{siteId}": { "schema": "CulturalSite", "description": "Cultural sites and ancestral domains." },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications." },
    "/lessons/{lessonId}": { "schema": "Lesson", "description": "Educational lessons." },
    "/quizzes/{quizId}": { "schema": "Quiz", "description": "Lesson quizzes." }
  }
}
