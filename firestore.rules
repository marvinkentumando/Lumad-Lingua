rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - The user's UID.
    //   - displayName: string (optional) - The user's display name.
    //   - email: string (optional) - The user's email address.
    //   - role: string (required) - learner, contributor, validator, admin.
    //   - xp: number (required) - Total XP.
    //   - streak: number (required) - Current streak.
    //   - level: number (required) - Current level.
    //   - artifacts: list (optional) - Unlocked artifact IDs.
    //   - lastActive: timestamp (optional) - Last activity time.
    //
    // Collection: words
    // Document ID: wordId
    // Fields:
    //   - term: string (required) - The word or phrase.
    //   - meaning: string (required) - The translation.
    //   - contributorId: string (required) - UID of the contributor.
    //   - status: string (required) - pending, validated, rejected.
    //   - createdAt: timestamp (required) - Creation time.
    //
    // Collection: users/{userId}/reviews
    // Document ID: reviewId
    // Fields:
    //   - userId: string (required) - The user's UID.
    //   - wordId: string (required) - The word's ID.
    //   - nextReview: timestamp (required) - Next review time.
    //   - interval: number (required) - Review interval.
    //   - easeFactor: number (required) - Difficulty factor.
    //
    // Collection: challenges
    // Document ID: challengeId
    // Fields:
    //   - title: string (required) - Title of the challenge.
    //   - goalXp: number (required) - Goal XP.
    //   - currentXp: number (required) - Current XP.
    //   - endsAt: timestamp (required) - End time.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         request.auth.token.email == "tumando.marvinken@dnsc.edu.ph");
    }

    function isValidator() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'validator') || isAdmin());
    }

    function isContributor() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contributor') || isValidator());
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'xp', 'streak', 'level']) &&
             data.uid is string &&
             data.role in ['learner', 'contributor', 'validator', 'admin'] &&
             data.xp is number && data.xp >= 0 &&
             data.streak is number && data.streak >= 0 &&
             data.level is number && data.level >= 0;
    }

    function isValidWord(data) {
      return data.keys().hasAll(['term', 'pos', 'tag', 'category', 'filipino', 'english', 'definition', 'contributorId', 'status', 'createdAt']) &&
             data.term is string && data.term.size() > 0 && data.term.size() < 500 &&
             data.definition is string && data.definition.size() > 0 && data.definition.size() < 2000 &&
             data.contributorId is string &&
             data.status in ['pending', 'validated', 'rejected'] &&
             data.createdAt is timestamp;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'wordId', 'nextReview', 'interval', 'easeFactor']) &&
             data.userId == request.auth.uid &&
             data.wordId is string &&
             data.nextReview is timestamp &&
             data.interval is number && data.interval >= 0 &&
             data.easeFactor is number && data.easeFactor >= 1.3;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'learner' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && !isAdmin()) ? request.resource.data.role == resource.data.role : true);
      
      match /reviews/{reviewId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidReview(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    match /words/{wordId} {
      allow read: if isAuthenticated() && (resource.data.status == 'validated' || isContributor());
      allow create: if isContributor() && isValidWord(request.resource.data) && 
                    request.resource.data.contributorId == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if isValidator() && isValidWord(request.resource.data);
      allow delete: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      // Allow users to update currentXp via atomic increments (simplified for now)
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentXp', 'participants']);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
