rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - The user's UID.
    //   - displayName: string (optional) - The user's display name.
    //   - email: string (optional) - The user's email address.
    //   - role: string (required) - learner, contributor, validator, admin.
    //   - xp: number (required) - Total XP.
    //   - streak: number (required) - Current streak.
    //   - level: number (required) - Current level.
    //   - lastLessonDate: string (optional) - ISO date of last lesson.
    //   - artifacts: list (optional) - Unlocked artifact IDs.
    //   - lastActive: timestamp (optional) - Last activity time.
    //
    // Collection: words
    // Document ID: wordId
    // Fields:
    //   - term: string (required) - The word or phrase.
    //   - meaning: string (required) - The translation.
    //   - contributorId: string (required) - UID of the contributor.
    //   - status: string (required) - pending, validated, rejected.
    //   - createdAt: timestamp (required) - Creation time.
    //
    // Collection: users/{userId}/reviews
    // Document ID: reviewId
    // Fields:
    //   - userId: string (required) - The user's UID.
    //   - wordId: string (required) - The word's ID.
    //   - nextReview: timestamp (required) - Next review time.
    //   - interval: number (required) - Review interval.
    //   - easeFactor: number (required) - Difficulty factor.
    //
    // Collection: challenges
    // Document ID: challengeId
    // Fields:
    //   - title: string (required) - Title of the challenge.
    //   - goalXp: number (required) - Goal XP.
    //   - currentXp: number (required) - Current XP.
    //   - endsAt: timestamp (required) - End time.
    //
    // Collection: cultural_sites
    // Document ID: siteId
    // Fields:
    //   - name: string (required)
    //   - community: string (required)
    //   - type: string (required)
    //   - coords: list (required) - [lat, lng]
    //   - population: number (required)
    //   - dialect: string (required)
    //   - status: string (required)
    //   - description: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "tumando.marvinken@dnsc.edu.ph" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidator() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'validator') || isAdmin());
    }

    function isContributor() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contributor') || isValidator());
    }

    function isEducator() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'educator') || isAdmin());
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.role in ['learner', 'contributor', 'validator', 'educator', 'admin'] &&
             (!('xp' in data) || data.xp is number) &&
             (!('streak' in data) || data.streak is number) &&
             (!('level' in data) || data.level is number) &&
             (!('lives' in data) || (data.lives is number && data.lives >= 0 && data.lives <= 5)) &&
             (!('onboarded' in data) || data.onboarded is bool) &&
             (!('completedLessons' in data) || data.completedLessons is list) &&
             (!('lastLifeLostAt' in data) || data.lastLifeLostAt == null || data.lastLifeLostAt is string) &&
             (!('lastLessonDate' in data) || data.lastLessonDate is string);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.type in ['validation', 'challenge', 'system', 'social'] &&
             data.read is bool &&
             data.createdAt is timestamp;
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['title', 'educatorId', 'dialect', 'difficulty', 'status', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.educatorId == request.auth.uid &&
             data.dialect is string &&
             data.difficulty in ['beginner', 'intermediate', 'advanced'] &&
             data.status in ['draft', 'published'] &&
             data.createdAt is timestamp;
    }

    function isValidQuiz(data) {
      return data.keys().hasAll(['lessonId', 'title', 'questions', 'createdAt']) &&
             data.lessonId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.questions is list &&
             data.createdAt is timestamp;
    }

    function isValidWord(data) {
      return data.keys().hasAll(['term', 'pos', 'tag', 'category', 'filipino', 'english', 'definition', 'contributorId', 'status', 'createdAt', 'dialect']) &&
             data.term is string && data.term.size() > 0 && data.term.size() < 500 &&
             data.definition is string && data.definition.size() > 0 && data.definition.size() < 2000 &&
             data.contributorId is string &&
             data.dialect is string &&
             data.status in ['pending', 'validated', 'rejected'] &&
             data.createdAt is timestamp;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'wordId', 'nextReview', 'interval', 'easeFactor']) &&
             data.userId == request.auth.uid &&
             data.wordId is string &&
             data.nextReview is timestamp &&
             data.interval is number && data.interval >= 0 &&
             data.easeFactor is number && data.easeFactor >= 1.3;
    }

    function isValidCulturalSite(data) {
      return data.keys().hasAll(['name', 'community', 'type', 'coords', 'population', 'dialect', 'status', 'description']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.community is string &&
             data.type is string &&
             data.coords is list && data.coords.size() == 2 &&
             data.coords[0] is number && data.coords[1] is number &&
             data.population is number &&
             data.dialect is string &&
             data.status is string &&
             data.description is string && data.description.size() < 5000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'learner' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && !isAdmin()) ? request.resource.data.role == resource.data.role : true);
      allow delete: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidReview(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    match /words/{wordId} {
      allow read: if isAuthenticated() && (resource.data.status == 'validated' || isContributor());
      allow create: if isContributor() && isValidWord(request.resource.data) && 
                    request.resource.data.contributorId == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if isValidator() && isValidWord(request.resource.data);
      allow delete: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      // Allow users to update currentXp via atomic increments (simplified for now)
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentXp', 'participants']);
    }

    match /cultural_sites/{siteId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin(); // System creates notifications
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /lessons/{lessonId} {
      allow read: if isAuthenticated() && (resource.data.status == 'published' || isEducator());
      allow create: if isEducator() && isValidLesson(request.resource.data);
      allow update: if isEducator() && resource.data.educatorId == request.auth.uid && isValidLesson(request.resource.data);
      allow delete: if isEducator() && resource.data.educatorId == request.auth.uid;
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isEducator() && isValidQuiz(request.resource.data);
      allow update: if isEducator() && isValidQuiz(request.resource.data);
      allow delete: if isEducator();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
